# Servidor
PORT=3000
APP_URL=http://localhost:3000

# Admin (gere o hash com: node setup-admin.js)
ADMIN_USER=admin
ADMIN_PASS_HASH=$2a$10$SUBSTITUA_PELO_HASH_GERADO

# JWT (use uma string aleatória longa)
JWT_SECRET=substitua_por_uma_string_secreta_longa_aqui

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app

# Destinatário das notificações
ADMIN_EMAIL=seu@email.com

# Origem permitida (CORS)
ALLOWED_ORIGIN=http://localhost:3000
