# ===== PRODUÇÃO (VERCEL) =====
PORT=3000
APP_URL=https://ollirum.com.br

# Admin — GERAR NOVO HASH COM: node setup-admin.js
ADMIN_USER=admin
ADMIN_PASS_HASH=$2a$10$SUBSTITUA_PELO_HASH_GERADO

# JWT — GERAR COM: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=SUBSTITUA_POR_STRING_ALEATORIA_LONGA

# Supabase (PostgreSQL)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxxxx

# E-mail (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua_senha_de_app_google

# Admin email
ADMIN_EMAIL=seu@gmail.com

# CORS
ALLOWED_ORIGIN=https://ollirum.com.br
